# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables Template — copy this file to .env and fill in your keys
# .env is gitignored — never commit it with real keys
# ─────────────────────────────────────────────────────────────────────────────

# ── OPTION 1: Groq (free tier — recommended for getting started) ──────────────
# Sign up at https://console.groq.com → API Keys → Create key
GROQ_API_KEY=your_groq_key_here
CLAUDE_MODEL=groq/llama-3.3-70b-versatile

# ── OPTION 2: Anthropic Claude (pay-per-use) ──────────────────────────────────
# Get a key at https://console.anthropic.com/settings/keys
# Uncomment and set CLAUDE_MODEL to use Claude instead of Groq
# ANTHROPIC_API_KEY=your_anthropic_key_here
# CLAUDE_MODEL=anthropic/claude-3-5-haiku-latest

# ── OPTIONAL — Serper.dev web search for AI agents ───────────────────────────
# Free tier: 2,500 queries/month — https://serper.dev
# If not set, agents fall back to local DB + context only
# SERPER_API_KEY=your_serper_key_here
