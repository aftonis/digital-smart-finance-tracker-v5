# ─────────────────────────────────────────────────────────────────────────────
# Streamlit Cloud Secrets — TEMPLATE ONLY
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO USE THIS FILE
# --------------------
# 1. LOCAL DEV: Copy this file to `.streamlit/secrets.toml` and fill in your
#    keys. That file is gitignored so your real keys stay on your machine.
#    (You can also just use the repo's top-level `.env` file — either works.)
#
# 2. STREAMLIT CLOUD: Do NOT upload this file. Instead:
#    a) Go to your app on https://share.streamlit.io
#    b) Settings → Secrets
#    c) Paste the contents in TOML format (copy from this template)
#    d) Save — Streamlit Cloud injects them securely at runtime
#
# NEVER commit the real secrets.toml to git. The .gitignore is configured
# to exclude it, but double-check before every push.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — Anthropic API key for the AI Analysis tab (3-agent crew)
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY = "sk-ant-api03-REPLACE_WITH_YOUR_KEY"

# OPTIONAL — Override the default Claude model
# Cheaper/faster: "anthropic/claude-3-5-haiku-latest"
# Best quality:   "anthropic/claude-3-5-sonnet-20241022" (default)
CLAUDE_MODEL = "anthropic/claude-3-5-sonnet-20241022"

# OPTIONAL — Serper.dev key for live web search in the Expense Analyst agent
# Free tier = 2,500 queries/month. https://serper.dev
# If omitted, the agent falls back to the local DB + prompt context only.
# SERPER_API_KEY = "your_serper_key_here"
