# ─────────────────────────────────────────────────────────────────────────────
# Streamlit Cloud Secrets — TEMPLATE ONLY
# ─────────────────────────────────────────────────────────────────────────────
#
# HOW TO USE THIS FILE
# --------------------
# 1. LOCAL DEV: Copy this file to `.streamlit/secrets.toml` and fill in your
#    keys. That file is gitignored so your real keys stay on your machine.
#    (You can also use the repo's top-level `.env` file — either works.)
#
# 2. STREAMLIT CLOUD: Do NOT upload this file. Instead:
#    a) Go to your app on https://share.streamlit.io
#    b) Settings → Secrets
#    c) Paste the contents below (choose ONE provider block)
#    d) Save — Streamlit Cloud injects them securely at runtime
#
# NEVER commit the real secrets.toml to git. The .gitignore excludes it.
# ─────────────────────────────────────────────────────────────────────────────


# ── OPTION 1: Groq (free tier — recommended for getting started) ──────────────
# Sign up at https://console.groq.com → API Keys → Create key (free)
GROQ_API_KEY = "gsk_REPLACE_WITH_YOUR_GROQ_KEY"
CLAUDE_MODEL = "groq/llama-3.3-70b-versatile"


# ── OPTION 2: Anthropic Claude (pay-per-use) ──────────────────────────────────
# Get a key at https://console.anthropic.com/settings/keys
# Uncomment these lines and comment out the Groq block above if you prefer Claude.
# ANTHROPIC_API_KEY = "sk-ant-api03-REPLACE_WITH_YOUR_ANTHROPIC_KEY"
# CLAUDE_MODEL = "anthropic/claude-3-5-haiku-latest"


# ── OPTIONAL — Serper.dev web search ─────────────────────────────────────────
# Free tier = 2,500 queries/month. https://serper.dev
# If omitted, the Expense Analyst agent falls back to local DB + context only.
# SERPER_API_KEY = "your_serper_key_here"
